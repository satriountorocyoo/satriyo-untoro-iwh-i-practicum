# ==============================================================================
# KONFIGURASI PROYEK HUBSPOT PRACTICUM
# ==============================================================================
# Petunjuk: 
# 1. Salin file ini dan ubah namanya menjadi ".env" di folder yang sama.
# 2. Isi token rahasia dan ID objek kustom Anda di bawah ini.
# 3. PENTING: File ".env" asli tidak boleh diunggah ke GitHub demi alasan keamanan.
# ==============================================================================

# Token Akses Private App HubSpot Anda (Salin dari Settings -> Integrations -> Private Apps)
PRIVATE_APP_ACCESS_TOKEN=masukkan_private_app_access_token_anda_di_sini

# ID atau Nama API Objek Kustom Anda (Contoh: "pets", "p_pets", atau "2-246248260")
# Jika Anda membuat Custom Object dengan nama "Pets", biasanya API Name-nya adalah "pets" atau ID "2-XXXXXXX"
CUSTOM_OBJECT_ID=2-246248260

# Port lokal untuk menjalankan aplikasi Express (opsional, default 3000)
PORT=3000
