doctype html
html 
    head 
        title= title
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        .container
            h1 HubSpot Contacts List
            p.subtitle Managing CRM Contacts via API Integration (Standard Object Mode)
            
            .nav-actions
                //- Perintah Praktikum: Menambahkan tautan "Add to this table" di bagian atas ke "/update-cobj"
                a(href="/update-cobj" class="btn btn-primary") + Add to this table
            
            .table-wrapper
                if data && data.length > 0
                    table
                        thead
                            tr
                                th First Name
                                th Last Name
                                th Email Address
                        tbody
                            each record in data
                                tr
                                    td(style="font-weight: 600; color: white;") #{record.properties.firstname || 'N/A'}
                                    td
                                        span.badge.badge-accent #{record.properties.lastname || 'N/A'}
                                    td
                                        span.badge #{record.properties.email || 'N/A'}
                else
                    .empty-state
                        svg(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor")
                            path(stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z")
                        h3 No Contacts Found
                        p.subtitle Create your first CRM contact record by clicking "Add to this table" above.
            
            footer
                p 🛠️ HubSpot Academy Practicum | Developed by Satriyo Untoro
